model Product {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String
  price         Float
  oldPrice      Float?
  stock         Int         @default(0)

  images        String[]
  tags          String[]

  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])

  createdAt     DateTime    @default(now())
}